#!/usr/bin/env bash

# Author 	 -  z0mbi3
# Source 	 -  https://github.com/gh0stzk/dotfiles
# Maintainer -  z0mbi3.zk@protonmail.com

dir="$HOME/.config/bspwm"
rofi_command="rofi -theme $HOME/.config/bspwm/scripts/RiceSelector.rasi"

# Options
emilia="๓ฐ”ฟ Emilia"
jan="๓ฐ”ฟ Jan"
aline="๓ฐ”ฟ Aline"
isabel="๓ฐ”ฟ Isabel"
andrea="๓ฐ”ฟ Andrea"
cynthia="๓ฐ”ฟ Cynthia"
silvia="๓ฐ”ฟ Silvia"
melissa="๓ฐ”ฟ Melissa"
pamela="๓ฐ”ฟ Pamela"
cristina="๓ฐ”ฟ Cristina"
karla="๓ฐ”ฟ Karla"
z0mbi3="๓ฐ”ฟ z0mbi3"

options="$emilia\n$jan\n$aline\n$isabel\n$andrea\n$cynthia\n$silvia\n$melissa\n$pamela\n$cristina\n$karla\n$z0mbi3"
chosen="$(printf "$options" | $rofi_command -dmenu)"
case $chosen in

$emilia)
	cat <<<"emilia" >$dir/rice.cfg
	bspc wm -r
	;;
$jan)
	cat <<<"jan" >$dir/rice.cfg
	bspc wm -r
	;;
$aline)
	cat <<<"aline" >$dir/rice.cfg
	bspc wm -r
	;;
$isabel)
	cat <<<"isabel" >$dir/rice.cfg
	bspc wm -r
	;;
$andrea)
	cat <<<"andrea" >$dir/rice.cfg
	bspc wm -r
	;;
$cynthia)
	cat <<<"cynthia" >$dir/rice.cfg
	bspc wm -r
	;;
$silvia)
	cat <<<"silvia" >$dir/rice.cfg
	bspc wm -r
	;;
$melissa)
	cat <<<"melissa" >$dir/rice.cfg
	bspc wm -r
	;;
$pamela)
	cat <<<"pamela" >$dir/rice.cfg
	bspc wm -r
	;;
$cristina)
	cat <<<"cristina" >$dir/rice.cfg
	bspc wm -r
	;;
$karla)
	cat <<<"karla" >$dir/rice.cfg
	bspc wm -r
	;;
$z0mbi3)
	cat <<<"z0mbi3" >$dir/rice.cfg
	bspc wm -r
	;;
esac
